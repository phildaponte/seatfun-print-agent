# Copy to .env and fill in. Never commit .env.

# HTTP server (loopback only — do not change to 0.0.0.0)
SEATFUN_AGENT_HOST=127.0.0.1
SEATFUN_AGENT_PORT=9787

# Bearer token — DEV OVERRIDE ONLY.
# In production the agent stores the bearer in the OS keychain after pairing via
# POST /v1/pair. Set this only for `npm run smoke` / integration tests / one-off
# manual curls. When set, /v1/pair is disabled.
# SEATFUN_AGENT_TOKEN=dev-replace-me-with-a-long-random-string

# Browser origins allowed by CORS (CSV). Defaults to app.seatfun.com + localhost:3000.
# SEATFUN_ALLOWED_ORIGINS=https://app.seatfun.com,http://localhost:3000

# Outbound heartbeat to the dashboard (scaffolded but disabled by default in v1-lite).
# When unset, the dashboard polls /v1/status instead.
# SEATFUN_HEARTBEAT_URL=https://app.seatfun.com/api/box-office/agent-heartbeat
# SEATFUN_HEARTBEAT_INTERVAL_MS=60000

# BOCA Lemur printer (Ethernet)
# Get this from the self-test ticket (hold TEST button ~3s on the printer).
PRINTER_IP=192.168.1.47
PRINTER_PORT=9100

# Logging
LOG_LEVEL=info
