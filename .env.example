# Copy to .env and fill in. Never commit .env.

# HTTP server (loopback only — do not change to 0.0.0.0)
SEATFUN_AGENT_HOST=127.0.0.1
SEATFUN_AGENT_PORT=9787

# Bearer token required for /v1/print and other protected routes.
# In v0 this is a static dev token. v1 will store it in the OS keychain after pairing.
SEATFUN_AGENT_TOKEN=dev-replace-me-with-a-long-random-string

# BOCA Lemur printer (Ethernet)
# Get this from the self-test ticket (hold TEST button ~3s on the printer).
PRINTER_IP=192.168.1.47
PRINTER_PORT=9100

# Logging
LOG_LEVEL=info
